default_platform(:android)

platform :android do

  # ---------------------------------------------------------------------------
  # Lane: internal — deploy su Internal Testing (branch develop)
  # ---------------------------------------------------------------------------
  desc "Build e deploy su Google Play Internal Testing"
  lane :internal do
    build_aab(env: "test")
    upload_to_play_store(
      track: "internal",
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
    UI.success "Deploy su Internal Testing completato!"
  end

  # ---------------------------------------------------------------------------
  # Lane: production — deploy su Production (branch main / tag)
  # ---------------------------------------------------------------------------
  desc "Build e deploy su Google Play Production"
  lane :production do
    build_aab(env: "prod")
    upload_to_play_store(
      track: "production",
      aab: "android/app/build/outputs/bundle/release/app-release.aab",
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
    UI.success "Deploy su Production completato!"
  end

  # ---------------------------------------------------------------------------
  # Helper privato: build AAB firmato
  # ---------------------------------------------------------------------------
  private_lane :build_aab do |options|
    env = options[:env] || "prod"

    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: "android/",
      properties: {
        "android.injected.signing.store.file"     => ENV["KEYSTORE_PATH"],
        "android.injected.signing.store.password" => ENV["KEYSTORE_PASSWORD"],
        "android.injected.signing.key.alias"      => ENV["KEY_ALIAS"],
        "android.injected.signing.key.password"   => ENV["KEY_PASSWORD"],
        # Passa ENV al bundle React Native
        "ENV" => env,
      }
    )
  end

end
