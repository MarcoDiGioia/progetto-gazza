{
  "extends": "@tsconfig/react-native/tsconfig.json",
  "compilerOptions": {
    "jsx": "react-native",
    "lib": ["es2021"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@shared/*": ["../shared/src/*"],
      "react": ["./node_modules/@types/react"],
      "react-native": ["./node_modules/@types/react-native"],
      "date-fns": ["./node_modules/date-fns"],
      "date-fns/*": ["./node_modules/date-fns/*"]
    }
  },
  "include": ["src", "index.js", "App.tsx", "../shared/src"],
  "exclude": ["node_modules"]
}
